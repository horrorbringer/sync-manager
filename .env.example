FLASK_SECRET_KEY=replace-with-a-long-random-value
# Generate with: flask --app run.py generate-encryption-key
FLASK_CREDENTIAL_ENCRYPTION_KEY=paste-generated-key-here
FLASK_SQLALCHEMY_DATABASE_URI=sqlite:///sync_manager.db
# inline: no Redis required; celery: background jobs through Redis
FLASK_SYNC_EXECUTION_MODE=inline
# Required only when FLASK_SYNC_EXECUTION_MODE=celery
FLASK_CELERY__BROKER_URL=redis://localhost:6379/0
FLASK_CELERY__RESULT_BACKEND=redis://localhost:6379/1
